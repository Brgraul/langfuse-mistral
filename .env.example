# Copy to .env and fill in. .env is gitignored.

# --- Mistral ---
MISTRAL_API_KEY=

# --- Langfuse ---
# EU cloud: https://cloud.langfuse.com  |  US cloud: https://us.cloud.langfuse.com
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
# Optional label shown on every observation (for example development or production).
LANGFUSE_TRACING_ENVIRONMENT=development

# --- HuggingFace (usually NOT needed for CORD v2; set only if you hit rate limits) ---
# HF_TOKEN=
